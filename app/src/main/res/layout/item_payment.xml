<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="11dp"
    android:background="@drawable/card_bg" android:layout_marginBottom="5dp"
    android:gravity="center_vertical">
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_pay_no" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textStyle="bold" android:textColor="@color/text_primary"/>
        <TextView android:id="@+id/tv_pay_label" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="10sp" android:textColor="@color/text_secondary"/>
    </LinearLayout>
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical" android:gravity="end">
        <TextView android:id="@+id/tv_pay_amount" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="12sp"
            android:textStyle="bold" android:textColor="@color/sage"/>
        <TextView android:id="@+id/tv_pay_sisa" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textSize="10sp" android:textColor="@color/text_secondary"/>
    </LinearLayout>
</LinearLayout>
