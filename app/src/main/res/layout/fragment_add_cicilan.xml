<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
        <Button android:id="@+id/btn_back" android:layout_width="32dp" android:layout_height="32dp"
            android:text="‹" android:textSize="18sp" android:padding="0dp"
            style="@style/Widget.Material3.Button.TextButton" android:layout_marginEnd="10dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tambah Cicilan" android:textSize="17sp" android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="14dp">

            <!-- Nama -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Nama cicilan" android:textSize="11sp" android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="4dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_nama" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Contoh: Cicilan HP Budi"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Category grid -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Kategori" android:textSize="11sp" android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="6dp"/>
            <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:columnCount="4" android:layout_marginBottom="12dp">

                <LinearLayout android:id="@+id/cat_hp" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
                    android:padding="8dp" android:layout_marginEnd="4dp" android:background="@drawable/cat_btn_bg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📱" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="HP/Gadget" android:textSize="9sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cat_motor" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
                    android:padding="8dp" android:layout_marginHorizontal="2dp" android:background="@drawable/cat_btn_bg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏍" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Motor" android:textSize="9sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cat_barang" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
                    android:padding="8dp" android:layout_marginHorizontal="2dp" android:background="@drawable/cat_btn_bg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📦" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Barang" android:textSize="9sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>

                <LinearLayout android:id="@+id/cat_lainnya" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_columnWeight="1" android:orientation="vertical" android:gravity="center"
                    android:padding="8dp" android:layout_marginStart="4dp" android:background="@drawable/cat_btn_bg">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📋" android:textSize="18sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Lainnya" android:textSize="9sp" android:textColor="?attr/colorOnSurfaceVariant"/>
                </LinearLayout>
            </GridLayout>

            <!-- Total -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Total hutang (Rp)" android:textSize="11sp" android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="4dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_total" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="0"
                    android:inputType="numberDecimal" android:textSize="20sp" android:textStyle="bold"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Cicilan & Tenor -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Cicilan/bulan (Rp)" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_cicilan" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:hint="0"
                            android:inputType="numberDecimal"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                    android:orientation="vertical" android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tenor (bulan)" android:textSize="11sp" android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="4dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_tenor" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:hint="12"
                            android:inputType="number"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Dari -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Dari (opsional)" android:textSize="11sp" android:textStyle="bold"
                android:textColor="?attr/colorOnSurfaceVariant" android:layout_marginBottom="4dp"/>
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_dari" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Bank / nama orang"
                    android:inputType="text"/>
            </com.google.android.material.textfield.TextInputLayout>

            <Button android:id="@+id/btn_simpan" android:layout_width="match_parent"
                android:layout_height="48dp" android:text="Simpan cicilan"
                android:backgroundTint="@color/red" style="@style/Widget.Material3.Button"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
