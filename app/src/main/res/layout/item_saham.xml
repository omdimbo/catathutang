<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="13dp"
    android:layout_marginBottom="7dp"
    app:cardCornerRadius="13dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">

        <TextView android:id="@+id/tv_ticker"
            android:layout_width="44dp" android:layout_height="44dp"
            android:gravity="center" android:textSize="10sp" android:textStyle="bold"
            android:background="@drawable/card_bg"
            android:layout_marginEnd="10dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_kode" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textStyle="bold" android:textColor="?attr/colorOnSurface"/>
            <TextView android:id="@+id/tv_nama" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="?attr/colorOnSurfaceVariant" android:maxLines="1"
                android:ellipsize="end"/>
            <TextView android:id="@+id/tv_volume" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:textColor="?attr/colorOnSurfaceVariant"/>
        </LinearLayout>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="vertical" android:gravity="end">
            <TextView android:id="@+id/tv_harga" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textStyle="bold" android:textColor="?attr/colorOnSurface"/>
            <TextView android:id="@+id/tv_change" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp" android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
