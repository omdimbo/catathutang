<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cream">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="16dp" android:paddingVertical="14dp"
        android:gravity="center_vertical" android:background="@color/bg_card">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CatatHutang" android:textSize="20sp" android:textStyle="bold"
                android:textColor="@color/sage_dark" android:letterSpacing="0.01"/>
            <TextView android:id="@+id/tv_subtitle" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="0 catatan aktif"
                android:textSize="11sp" android:textColor="@color/text_secondary"/>
        </LinearLayout>
        <TextView android:id="@+id/tv_user_avatar" android:layout_width="36dp"
            android:layout_height="36dp" android:gravity="center" android:textSize="12sp"
            android:textStyle="bold" android:textColor="@color/sage"
            android:background="@drawable/avatar_bg"/>
    </LinearLayout>

    <!-- Quote strip -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/sage_xlight"
        android:paddingHorizontal="14dp" android:paddingVertical="10dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&quot;" android:textSize="22sp" android:textColor="@color/sage"
            android:fontFamily="serif" android:layout_marginEnd="8dp" android:layout_marginTop="-2dp"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tv_quote" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="@color/sage_medium" android:textStyle="italic"
                android:lineSpacingMultiplier="1.5"/>
            <TextView android:id="@+id/tv_quote_author" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:textColor="@color/sage" android:layout_marginTop="3dp"/>
            <LinearLayout android:id="@+id/quote_dots" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginTop="6dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Summary row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="12dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="@drawable/card_bg" android:padding="12dp" android:layout_marginEnd="5dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Berhutang" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_berhutang" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Rp 0" android:textSize="13sp"
                android:textStyle="bold" android:textColor="@color/red_soft"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="@drawable/card_bg" android:padding="12dp" android:layout_marginHorizontal="5dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Piutang" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_piutang" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Rp 0" android:textSize="13sp"
                android:textStyle="bold" android:textColor="@color/sage"/>
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:background="@drawable/card_bg" android:padding="12dp" android:layout_marginStart="5dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Saldo" android:textSize="10sp" android:textColor="@color/text_secondary"/>
            <TextView android:id="@+id/tv_saldo" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Rp 0" android:textSize="13sp"
                android:textStyle="bold" android:textColor="@color/warm_accent"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Catatan aktif" android:textSize="11sp" android:textStyle="bold"
        android:textColor="@color/text_secondary" android:paddingHorizontal="14dp" android:paddingBottom="4dp"/>

    <TextView android:id="@+id/empty_state" android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Belum ada catatan.\nTap + untuk menambah." android:textSize="13sp"
        android:textColor="@color/text_hint" android:gravity="center"
        android:padding="32dp" android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recycler_hutang"
        android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"
        android:clipToPadding="false" android:paddingBottom="80dp"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_gravity="bottom|end"
        android:layout_margin="16dp" android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/sage" app:tint="@color/white"/>
</LinearLayout>
